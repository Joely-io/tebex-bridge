# ============================================================
# Tebex Bridge configuration
# Copy this file to `.env` and fill in your values.
# ============================================================

# --- Required ---

# Headless API webstore token (Tebex creator panel > Webstore > Settings > API Keys)
# Used for: store info, categories, packages
TEBEX_WEBSTORE_TOKEN=

# Shared secret used by Joely to sign every request to this bridge (HMAC-SHA256).
# Generated in the Joely dashboard when you enable the self-hosted bridge.
# Minimum 32 characters.
JOELY_SHARED_SECRET=

# --- Optional (enable only the features you use in Joely) ---

# Plugin API secret key (Tebex creator panel > Game Servers)
# Used for: customer payment lookup, coupons, gift cards
TEBEX_SECRET_KEY=

# Checkout API credentials (Tebex creator panel > Webstore > Settings > API Keys)
# Used for: transaction/payment details
TEBEX_STORE_ID=
TEBEX_PRIVATE_KEY=

# --- Server ---

# Port the bridge listens on (default: 3000)
PORT=3000
