{
  "name": "tebex-bridge",
  "version": "1.0.0",
  "description": "Self-hosted bridge that securely connects Tebex to Joely while keeping your API keys on your own server.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
